# LLM — 默认使用阿里百炼 Dashscope
LLM_PROVIDER=dashscope
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 (备用)
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4-flash

# OpenAI (可选)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# OLLAMA_BASE_URL=http://localhost:11434

# 硅基流动 (测试点/测试用例生成推荐)
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.5
LLM_FALLBACK_PROVIDER=zhipu

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sisyphus
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/sisyphus

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sisyphus

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_ENV=development
APP_DEBUG=true
